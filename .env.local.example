# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Who receives the contact form submissions
CONTACT_TO=you@example.com

# Sender shown in the email — must be a verified domain in production.
# Leave unset to use Resend's test sender (onboarding@resend.dev).
EMAIL_FROM=Contact Form <you@yourdomain.com>
